# Basjoo 智能体（agent）系统环境配置示例
# 复制此文件为 .env 并根据需要修改配置

# ========== 数据库配置 ==========
# PostgreSQL (生产环境推荐)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=

# SQLite (开发环境可选)
# DATABASE_URL=sqlite:////app/data/basjoo.db

# ========== Redis 配置 ==========
# REDIS_URL=redis://host:6379/0
REDIS_URL=
REDIS_CACHE_TTL=3600
REDIS_RATE_LIMIT_TTL=60

# ========== Qdrant 向量数据库配置 ==========
QDRANT_HOST=
QDRANT_PORT=6333
# QDRANT_API_KEY=  # 可选，用于 Qdrant Cloud

# ========== JWT 认证配置 ==========
# 零配置部署下可留空：启动时会自动生成并持久化到 SECRET_KEY_FILE
# 如需自定义，请填入强随机值
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ========== CORS 配置 ==========
# 零配置部署默认最大放行，优先保证 Widget 与管理后台先可用
# 正式上线后建议收紧为你的实际域名列表
ALLOWED_ORIGINS=*
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,Accept

# ========== LLM API 配置 ==========
# 根据使用的 AI 提供商配置对应的 API Key

# DeepSeek (默认)
DEEPSEEK_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# Anthropic Claude
# ANTHROPIC_API_KEY=

# Google Gemini
# GOOGLE_API_KEY=

# Azure OpenAI
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=

# ========== URL 抓取配置 ==========
# Jina API (可选，提供更好的 URL 抓取能力)
# JINA_API_KEY=

# ========== Cloudflare Turnstile（可选） ==========
# 启用 Widget Bot 保护时需要配置
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ========== 应用配置 ==========
APP_NAME=Basjoo
APP_PORT=8000

# ========== HTTPS 配置（可选） ==========
# 将证书文件放到项目根目录 ./ssl/ 后会自动启用 HTTPS（443 端口）
# cert.pem 或 fullchain.pem - SSL 证书文件
# key.pem                   - SSL 私钥文件
#
# 不配置证书时，仅 HTTP（80 端口）可用

# 限流配置
DEFAULT_RATE_LIMIT=100
RATE_LIMIT_PER_MINUTE=1000
RATE_LIMIT_BURST_SIZE=200

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ========== API Key 加密配置（可选） ==========
# 零配置部署下可留空：bootstrap-env.sh 会自动生成 ENCRYPTION_KEY
# 系统首次启动时也可自动生成加密密钥并保存到 /app/data/.encryption_key
ENCRYPTION_KEY=
# 如需自定义密钥文件路径：
SECRET_KEY_FILE=/app/data/.secret_key
ENCRYPTION_KEY_FILE=/app/data/.encryption_key
